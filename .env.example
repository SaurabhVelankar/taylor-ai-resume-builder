# Copy this file to .env.local and fill in values:
#   cp .env.example .env.local

# Your name — used only to label generated files (Resume_{Your_Name}_{Company}.pdf).
# Leave blank to get plain "Resume_{Company}.pdf". Exposed to the browser (NEXT_PUBLIC_).
NEXT_PUBLIC_RESUME_OWNER_NAME=

# Google AI Studio / Gemini API key
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model IDs (override if needed)
GEMINI_MODEL_PRO=gemini-2.5-flash
GEMINI_MODEL_FLASH=gemini-2.5-flash

# When true (or when GEMINI_API_KEY is empty), parse/cascade use local mocks
# so you can explore the UI with no API key. Set to false to call Gemini.
DEMO_MODE=true

# Application tracker backend: local (default) | redis | supabase
# "local" stores records as JSON under data/applications/ (gitignored).
# redis/supabase are placeholders for a future cloud swap.
TRACKER_STORE=local
# Placeholders for later cloud backends (leave unset while using local):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Tracker pace goals (exposed to the /applications analytics panel).
# Weeks are Monday–Sunday (local calendar). Set to 0 to hide a goal meter.
NEXT_PUBLIC_TRACKER_DAILY_GOAL=5
NEXT_PUBLIC_TRACKER_WEEKLY_GOAL=25
NEXT_PUBLIC_TRACKER_MONTHLY_GOAL=100
NEXT_PUBLIC_TRACKER_LIFETIME_GOAL=0
